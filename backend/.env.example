# ── Database ─────────────────────────────────────────────────────────────────
# Railway PostgreSQL 플러그인 추가 시 DATABASE_URL이 자동 주입됨
# asyncpg 드라이버: postgresql+asyncpg://
# psycopg2 드라이버: postgresql://  (alembic 마이그레이션용)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway Redis 플러그인 추가 시 REDIS_URL 자동 주입됨 (없으면 캐시 비활성화)
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# openssl rand -hex 32 으로 생성 권장
SECRET_KEY=change-this-to-a-random-256-bit-secret
DEBUG=false

# ── Kakao ─────────────────────────────────────────────────────────────────────
KAKAO_REST_API_KEY=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=pawgo-assets
