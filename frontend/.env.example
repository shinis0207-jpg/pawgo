EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── 지도 Provider ──────────────────────────────────────────────────────────
# kakao (기본) 또는 google 중 하나를 선택
EXPO_PUBLIC_MAP_PROVIDER=kakao

# 카카오 지도 JavaScript SDK 앱 키 (카카오 개발자 콘솔 → 앱 설정 → 앱 키 → JavaScript 키)
EXPO_PUBLIC_KAKAO_MAP_KEY=your-kakao-javascript-api-key

# Google Maps (MAP_PROVIDER=google 로 전환 시 사용)
# Google Cloud Console → Maps SDK for Android/iOS 활성화 후 입력
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key
