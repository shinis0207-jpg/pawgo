{
  "expo": {
    "name": "PawGo",
    "slug": "pawgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pawgo.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "현재 위치 기반 반려동물 동반 장소를 찾기 위해 위치 정보가 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.pawgo.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-location"
    ],
    "scheme": "pawgo",
    "updates": {
      "enabled": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "063b52bd-862e-4e4f-aeeb-b533189f9f0b"
      }
    }
  }
}
