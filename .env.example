# ── 지도 ───────────────────────────────────────────────────────────────────
# kakao | google  (기본값 kakao)
EXPO_PUBLIC_MAP_PROVIDER=kakao

# 카카오 개발자 콘솔 → 내 애플리케이션 → 앱 키 → JavaScript 키
EXPO_PUBLIC_KAKAO_MAP_JS_KEY=

# 카카오 개발자 콘솔 → 내 애플리케이션 → 앱 키 → REST API 키
# 백엔드 API 호출 및 시드 스크립트에서 사용
KAKAO_REST_API_KEY=

# ── 백엔드 DB ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pawgo:pawgo@localhost:5432/pawgo
DATABASE_URL_SYNC=postgresql://pawgo:pawgo@localhost:5432/pawgo
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-this-in-production

# ── AI ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OAuth (선택) ───────────────────────────────────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 프론트엔드 API 주소 ────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
